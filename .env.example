# =============================================
# PixVerifyBot — Environment Configuration
# =============================================
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# External API (Google One generation service)
EXTERNAL_API_BASE_URL=https://iqless.icu
EXTERNAL_API_KEY=ak_XXXX-XXXX-XXXX-XXXX-XXXX-XXXX-XXXX-XXXX

# Admin Configuration (comma-separated Telegram user IDs)
ADMIN_USER_IDS=123456789

# Links
COMMUNITY_LINK=https://t.me/your_community_channel
SUPPORT_CONTACT=@your_support_username

# Credit Pricing (base rate $2.50 per credit, volume discounts built into plans)
CREDIT_PRICE_USD=2.5

# Credit Plans — To modify plans without code changes, uncomment and edit:
# CREDIT_PACKAGES=[{"label":"Starter","credits":1,"price":"2.50"},{"label":"Basic","credits":5,"price":"12.00"},{"label":"Standard","credits":10,"price":"23.00"},{"label":"Pro","credits":20,"price":"44.00"},{"label":"Advanced","credits":50,"price":"105.00"},{"label":"Bulk","credits":100,"price":"200.00"}]

# =============================================
# Payment: USDT BEP-20 (BSC Network) — Auto-detected
# =============================================
# Your BSC wallet address to receive USDT payments
USDT_BEP20_WALLET_ADDRESS=0xYourBscWalletAddressHere

# BscScan API key for monitoring incoming transfers
# Get one free at https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key_here

# =============================================
# Payment: Binance Transfer — Admin confirms manually
# =============================================
# Your Binance Pay ID (found in Binance app → Pay → My Pay ID)
BINANCE_PAY_ID=your_binance_pay_id_here

# =============================================
# Payment Monitoring
# =============================================
# How often to check for incoming payments (ms)
PAYMENT_MONITOR_INTERVAL_MS=15000
# How long before pending orders expire (minutes)
PAYMENT_ORDER_EXPIRY_MINUTES=60

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_RUN_MAX=3

# Database
DB_PATH=./data/pixverify.db

# Logging
LOG_LEVEL=info
LOG_FILE=./data/logs/bot.log

# New user starting credits (set to 0 for production)
DEFAULT_CREDITS=0
